{
  "name": "lenlearn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev": "node --env-file=.env scripts/dev.mjs",
    "dev:web": "vite",
    "dev:auth": "node --env-file=.env server/index.js",
    "build": "vite build",
    "test": "node --test --test-timeout=120000",
    "test:verbose": "node --test --test-reporter=spec --test-timeout=120000",
    "test:auth": "node --test tests/auth-*.test.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "migrate": "npx auth@latest migrate --yes --config server/auth.js",
    "migrate:cli": "npx @better-auth/cli migrate --yes --config server/auth.js",
    "pg:ping": "node scripts/postgres-ping.mjs",
    "pg:sections-schema": "node scripts/ensure-postgres-sections-table.mjs",
    "pg:subjects-schema": "node scripts/ensure-postgres-subjects-table.mjs",
    "pg:announcements-schema": "node scripts/ensure-postgres-announcements-table.mjs",
    "pg:activity-tracking": "node scripts/ensure-postgres-activity-tracking.mjs",
    "seed": "npx cross-env AUTH_DISABLE_SIGNUP=false node server/seed.mjs",
    "ensure:teacher": "npx cross-env AUTH_DISABLE_SIGNUP=false node scripts/ensure-teacher-account.mjs",
    "ensure:faderek": "npx cross-env AUTH_DISABLE_SIGNUP=false TEACHER_EMAIL=adolfo.jbukele@gmail.com TEACHER_USERNAME=faderek TEACHER_PASSWORD=ChangeMe#Strong1 TEACHER_ENABLE_2FA=1 node scripts/ensure-teacher-account.mjs",
    "purge:demo-teacher": "node scripts/purge-demo-teacher-account.mjs",
    "auth:delete-user": "node scripts/delete-auth-user-by-username.mjs",
    "auth:clear-jwks": "node scripts/clear-auth-jwks.mjs",
    "verify:jwks": "node scripts/verify-jwks.mjs"
  },
  "dependencies": {
    "@better-auth/infra": "^0.1.14",
    "@tabler/icons-webfont": "^3.44.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.2.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.14.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.15.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1"
  }
}
