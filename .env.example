# Required (min 32 chars, random). CLI migrate and the auth server read this.
# Do not use a short placeholder. Generate one, then paste on the line below (no spaces around =):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   npx auth secret
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# AES-256-GCM for student PII at rest (first_name, last_name, contact_no, parent_contact, dob, address).
# 32-byte key as 64 hex chars: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_256_SECRET_KEY=
# If you rotate this secret and see "Failed to decrypt private key" (JWKS / 2FA), run: npm run auth:clear-jwks
# JWT private keys and 2FA OTP/backup codes are encrypted at rest by default (BETTER_AUTH_SECRET).
# Legacy plaintext JWKS only: set BETTER_AUTH_JWKS_DISABLE_ENCRYPTION=true temporarily, then clear jwks and unset.
# BETTER_AUTH_JWKS_DISABLE_ENCRYPTION=true
# Optional: on startup, delete all rows in `jwks` (tests use this; do not enable in production unless you understand the impact).
# BETTER_AUTH_RESET_JWKS=1

# Public URL the browser uses (must match the site you open — e.g. ngrok https URL)
BETTER_AUTH_URL=http://localhost:5173

# Vite frontend: set to the same origin as BETTER_AUTH_URL when auth + `/api/v1/state` run on
# ngrok (or another public host) while you open the UI from localhost — so cookies and CORS align.
# Trailing slash is optional; omit when using the Vite dev proxy only.
# VITE_AUTH_BASE_URL=https://your-subdomain.ngrok-free.dev

# Optional: enable Better Auth Infra client plugins (Sentinel fingerprint + Dash) during `vite` dev.
# Default is off so `/two-factor/verify-otp` is not delayed by KV identify / PoW retries on localhost.
# VITE_BETTER_AUTH_INFRA_CLIENT=1

# Optional: max milliseconds for the faculty dashboard to wait on GET `/api/v1/state` (default 8000).
# VITE_LMS_STATE_FETCH_MS=8000

# Optional: max .lnbak restore upload size (default 0 = unlimited). Examples: 500mb, 1073741824
# BACKUP_RESTORE_MAX_BYTES=0

# ── Google Drive backup (admin OAuth — uploads .lnbak files automatically) ──
# Create credentials at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, Web application).
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Cloud "Authorized redirect URIs" exactly. Local dev: use Vite port (5173), not the auth API port (3001).
# If unset, derived from BETTER_AUTH_URL + /api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
GOOGLE_DRIVE_FOLDER_NAME=LenLearn Backups
# Optional: where to send the browser after OAuth consent (defaults to BETTER_AUTH_URL + /admin/backup)
# GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/admin/backup

# Set true when the browser UI is on a different site than BETTER_AUTH_URL (e.g. localhost + ngrok HTTPS API).
# Sets session cookies to SameSite=None; Secure (requires HTTPS on BETTER_AUTH_URL). Then sign in again.
# BETTER_AUTH_CROSS_ORIGIN_COOKIES=true

# Extra allowed origins (comma-separated), e.g. https://abc.ngrok-free.app
# BETTER_AUTH_TRUSTED_ORIGINS=https://your-subdomain.ngrok-free.app

# @better-auth/infra `dash()` — Better Auth Dash API key (required for Infra dashboard + audit logs in production)
BETTER_AUTH_API_KEY=
# When BETTER_AUTH_API_KEY is set, Dash activity tracking is off in development unless you set:
# BETTER_AUTH_DASH_ACTIVITY=true
# Optional: ms between lastActiveAt updates (default 300000 = 5 minutes)
# BETTER_AUTH_ACTIVITY_INTERVAL_MS=300000

# Optional: Better Auth Infra endpoints (Sentinel + Dash). Defaults are fine if omitted.
# BETTER_AUTH_API_URL=https://dash.better-auth.com
# BETTER_AUTH_KV_URL=https://kv.better-auth.com

# Optional: enable Sentinel security checks that call Infra `/security/*` endpoints.
# - In production: defaults to enabled.
# - In development: defaults to disabled to avoid noisy logs if Infra is down/misconfigured.
INFRA_SECURITY_ENABLED=true

# Auth API (Express). Vite proxies /api/auth → this server.
# `npm run dev` picks a free port from this value upward and sets VITE_PROXY_AUTH_PORT for you.
AUTH_SERVER_PORT=3001

# Set to false only when running seed or a controlled signup window
AUTH_DISABLE_SIGNUP=true

# Account lockout after 5 failed sign-ins (milliseconds). Default: 300000 (5 min).
# AUTH_LOCK_MS=300000

# Email OTP 2FA (Better Auth twoFactor plugin). NEVER true in production — automated tests only.
AUTH_TWO_FACTOR_SKIP_VERIFY_ON_ENABLE=false
# Production: exit on startup if any portal account lacks MFA (set false to warn only).
# AUTH_REQUIRE_MFA_ALL=true

# ── OTP Email Sender (sends verification codes to ALL users) ──
# Use a dedicated mailbox — NOT the institute admin account.
# Gmail App Password (NOT your regular Gmail password). Generate steps:
#   1. Sign in to the sender Gmail (e.g. noreply.lenlearnotp@gmail.com)
#   2. myaccount.google.com → Security → 2-Step Verification (enable first)
#   3. Security → App passwords → Create → name it "LenLearn LMS OTP"
#   4. Copy the 16-character password into SMTP_PASS below (spaces are ignored)
# With SMTP_HOST=smtp.gmail.com (default), the server uses Nodemailer `service: 'gmail'`.
# For raw host/port instead, set SMTP_USE_HOST_TRANSPORT=1 (SMTP_PORT 587 or 465).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply.lenlearnotp@gmail.com
SMTP_PASS=
SMTP_FROM="LenLearn LMS <noreply.lenlearnotp@gmail.com>"
# Optional: recipient for `npm run smtp:test` (defaults to SMTP_USER)
# SMTP_TEST_TO=olympus.grp123@gmail.com
# Set to 1 to print SMTP traffic in the auth server terminal (debugging only)
# SMTP_DEBUG=1
# On startup, transporter.verify() runs; set to 1 to exit the process if verify fails (CI / strict prod checks)
# SMTP_VERIFY_STRICT=1
# If SMTP send fails in development, print OTP to console only when this is 1 (default: off — failures surface as errors)
# AUTH_SMTP_DEV_FALLBACK=1

# ── Admin login account (NOT the SMTP sender) ──
# Default admin email is also in shared/constants.js → INSTITUTE_ADMIN_EMAIL
SEED_ADMIN_EMAIL=olympus.grp123@gmail.com
SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=Admin#1Strong

# ── School domain reference (faculty/student account emails) ──
# SCHOOL_DOMAIN=glendaleschool.edu

# Optional: sender address shown on the login OTP screen (defaults to noreply.lenlearnotp@gmail.com)
# VITE_OTP_SENDER_EMAIL=noreply.lenlearnotp@gmail.com

# --- Security evidence harness (npm run security:evidence) ---
# Optional credentials for live RBAC / logout evidence (server must be running)
# SECURITY_EVIDENCE_USERNAME=admin
# SECURITY_EVIDENCE_PASSWORD=YourAdminPassword
# SECURITY_EVIDENCE_STUDENT_USERNAME=student_login_id
# SECURITY_EVIDENCE_STUDENT_PASSWORD=StudentPassword
# SECURITY_EVIDENCE_FACULTY_USERNAME=faculty_code
# SECURITY_EVIDENCE_FACULTY_PASSWORD=FacultyPassword

# --- PostgreSQL (Better Auth + institute `/api/v1/state` + curriculum + activity logs) ---
# Create DB: `createdb lenlearn_db` (or use your host’s SQL UI), then apply Better Auth schema:
#   npx auth@latest migrate --yes --config server/auth.js
# LMS/feature DDL: apply files under Database/migrations/ as needed, e.g.:
#   psql $DATABASE_URL -f Database/migrations/004_sections_catalog_postgres.sql
# Sections catalog only: `npm run pg:sections-schema`
# Connectivity: `npm run pg:ping`
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/lenlearn_db
# Optional: max connections in the shared pool (default 10)
# PG_POOL_MAX=10

# Integration tests (`npm run test:auth`) use TEST_DATABASE_URL if set, otherwise DATABASE_URL.
# Use a disposable database when pointing at shared Postgres.
# TEST_DATABASE_URL=postgres://postgres:pass@localhost:5432/lenlearn_test

# --- Originality Checker (web search) ---
# Web source discovery uses DuckDuckGo HTML search only (no API key required).

# --- FREE-ONLY AI-Checker profile (recommended for capstone / no external API keys) ---
# PLAGIARISM_AI_PROVIDER=local
# Do not set OPENAI_API_KEY unless using openai embedding provider.
# See docs/AI_CHECKER_API_DISCLOSURE.md for panel defense and integration details.

# --- AI-Powered Plagiarism Checker (semantic embeddings) ---
# PLAGIARISM_AI_PROVIDER: local (default) | openai | off
# local = on-server embeddings via @xenova/transformers (no API key)
# openai = OpenAI Embeddings API (requires OPENAI_API_KEY)
# off = TF-IDF lexical analysis only (no semantic AI)
PLAGIARISM_AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

DATABASE_URL=
BETTER_AUTH_SECRET=
NODE_ENV=production
INFRA_SECURITY_ENABLED=true