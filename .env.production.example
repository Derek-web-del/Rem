# ══════════════════════════════
# LenLearn LMS — Production ENV
# ══════════════════════════════
# NEVER commit real values
# Generate new secrets for prod
# ══════════════════════════════

# Environment
NODE_ENV=production

# Database (Railway PostgreSQL — use Variable Reference on the web service, not localhost)
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Public HTTPS URL (Railway domain or custom domain)
BETTER_AUTH_URL=https://your-app.up.railway.app

# Better Auth Infra (optional — omit to skip dash/sentinel; app still starts)
# BETTER_AUTH_API_KEY=

# Reverse proxy (Railway sets trust proxy to 1 automatically in production)
# TRUST_PROXY=1
BETTER_AUTH_SECRET=GENERATE_NEW_VALUE
BETTER_AUTH_RESET_JWKS=
# NEVER set to 1 in production!

# AES-256 Encryption
# Generate: node -e "console.log(
#   require('crypto')
#   .randomBytes(32)
#   .toString('hex'))"
AES_256_SECRET_KEY=GENERATE_NEW_64_HEX_CHARS

# Security — NEVER true in prod!
AUTH_DISABLE_SIGNUP=true
AUTH_TWO_FACTOR_SKIP_VERIFY_ON_ENABLE=false
AUTH_REQUIRE_MFA_ALL=true

# Admin Seed (first time only)
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=GENERATE_STRONG_PASSWORD

# SMTP (Gmail App Password)
# Enable 2FA on Gmail first
# Then: myaccount.google.com
# → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply.lenlearnotp@gmail.com
SMTP_PASS=GMAIL_APP_PASSWORD_HERE
SMTP_FROM="LenLearn LMS <noreply.lenlearnotp@gmail.com>"

# Rate Limiting (production values)
RATE_LIMIT_MAX_SIGNIN=10
RATE_LIMIT_WINDOW_MS=900000

# File Upload Volume
UPLOAD_DIR=/app/public/uploads

# Optional: Google OAuth (future)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# DO NOT include in production:
# AUTH_SMTP_DEV_FALLBACK
# SECURITY_EVIDENCE_EMAIL
# LIVE_TEST_*
# BETTER_AUTH_RESET_JWKS=1
