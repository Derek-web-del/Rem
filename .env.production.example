# ══════════════════════════════
# LenLearn LMS — Production ENV
# ══════════════════════════════
# NEVER commit real values
# Generate new secrets for prod
# ══════════════════════════════

# Environment
NODE_ENV=production

# Database (Railway PostgreSQL — use Variable Reference on the web service, not localhost)
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Public HTTPS URL (Railway domain or custom domain)
BETTER_AUTH_URL=https://your-app.up.railway.app

# Better Auth Infra (optional — omit to skip dash/sentinel; app still starts)
# BETTER_AUTH_API_KEY=

# Reverse proxy — Cloudflare + DigitalOcean App Platform (two hops)
# TRUST_PROXY=2
# Single proxy hop (CDN or load balancer only): TRUST_PROXY=1
TRUST_PROXY=2
BETTER_AUTH_SECRET=GENERATE_NEW_VALUE
BETTER_AUTH_RESET_JWKS=
# NEVER set to 1 in production!

# AES-256 Encryption
# Generate: node -e "console.log(
#   require('crypto')
#   .randomBytes(32)
#   .toString('hex'))"
AES_256_SECRET_KEY=GENERATE_NEW_64_HEX_CHARS

# Security — NEVER true in prod!
AUTH_DISABLE_SIGNUP=true
AUTH_TWO_FACTOR_SKIP_VERIFY_ON_ENABLE=false
AUTH_REQUIRE_MFA_ALL=true

# Admin Seed (first time only)
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=GENERATE_STRONG_PASSWORD

# Email (2FA OTP, password reset)
# Railway Trial/Hobby blocks outbound SMTP (ports 25/465/587). Use Resend on Railway:
#   1. https://resend.com → API Keys → create key
#   2. Domains → verify your domain (or use onboarding@resend.dev for testing only)
#   3. Set RESEND_API_KEY and RESEND_FROM below; SMTP vars are optional on Railway
RESEND_API_KEY=
RESEND_FROM="LenLearn LMS <noreply@your-verified-domain.com>"

# SMTP (works locally and on Railway Pro; blocked on Railway Trial/Hobby)
# Gmail: enable 2FA, then App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply.lenlearnotp@gmail.com
SMTP_PASS=GMAIL_APP_PASSWORD_HERE
SMTP_FROM="LenLearn LMS <noreply.lenlearnotp@gmail.com>"

# Rate Limiting — logged-in API calls are per session; sign-in/OTP remain per IP
# Audit logs poll every 10s → need generous GET limits (default 3000/15min per user)
RATE_LIMIT_MAX_SIGNIN=30
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_SEND_OTP=15
RATE_LIMIT_MAX_VERIFY_OTP=20
RATE_LIMIT_MAX_GET=3000
RATE_LIMIT_MAX_POST=800
# Account lockout after 5 failed sign-ins (default 5 minutes)
AUTH_LOCK_MS=300000
# Infra Sentinel credential-stuffing is disabled in code; native lockout handles abuse.
# INFRA_SECURITY_ENABLED=true

# Database (DigitalOcean Managed Postgres — SSL required)
# DATABASE_URL=postgresql://doadmin:PASSWORD@HOST:25060/defaultdb?sslmode=require
# Or for self-signed certs on DO:
# DATABASE_URL=postgresql://doadmin:PASSWORD@HOST:25060/defaultdb?sslmode=no-verify
# Or with CA cert in repo root (see ca-certificate.crt):
# NODE_EXTRA_CA_CERTS=/workspace/ca-certificate.crt

# File storage — mount ONE DigitalOcean Volume at /data, then:
UPLOAD_DIR=/data/uploads
# BACKUP_DIR auto-resolves to /data/backups when UPLOAD_DIR is set (same volume)
# Or set explicitly:
# BACKUP_DIR=/data/backups

# Longer timeouts for large backup/restore on production
PG_QUERY_TIMEOUT_MS=120000
PG_CONNECT_TIMEOUT_MS=15000
EXPRESS_BODY_LIMIT=100mb

# Optional: Google OAuth (future)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# DO NOT include in production:
# AUTH_SMTP_DEV_FALLBACK
# SECURITY_EVIDENCE_EMAIL
# LIVE_TEST_*
# BETTER_AUTH_RESET_JWKS=1
